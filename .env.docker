# ============================================================
#  Health_Web — Environment Variables untuk Docker
#  SALIN file ini menjadi .env saat menjalankan docker-compose
# ============================================================

# PostgreSQL
POSTGRES_USER=health_user
POSTGRES_PASSWORD=strong_db_password_here
POSTGRES_DB=health_web_prod

# Backend
DATABASE_URL=postgresql://health_user:strong_db_password_here@health-db:5432/health_web_prod?schema=public
PORT=5000
NODE_ENV=production
