{
  "info": {
    "name": "Health Monitoring API",
    "description": "Postman collection for the Health Monitoring Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "monitorId",
      "value": "YOUR_MONITOR_ID",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "General",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "health"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Monitors",
      "item": [
        {
          "name": "Get All Monitors",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/monitors",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "monitors"
              ]
            }
          }
        },
        {
          "name": "Get Monitor by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/monitors/{{monitorId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "monitors",
                "{{monitorId}}"
              ]
            }
          }
        },
        {
          "name": "Create Monitor",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Google Test\",\n  \"url\": \"https://google.com\",\n  \"interval\": 60\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/monitors",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "monitors"
              ]
            }
          }
        },
        {
          "name": "Update Monitor",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Google Test Updated\",\n  \"url\": \"https://google.com\",\n  \"interval\": 120\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/monitors/{{monitorId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "monitors",
                "{{monitorId}}"
              ]
            }
          }
        },
        {
          "name": "Delete Monitor",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/monitors/{{monitorId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "monitors",
                "{{monitorId}}"
              ]
            }
          }
        },
        {
          "name": "Check Monitor Manually",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/monitors/{{monitorId}}/check",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "monitors",
                "{{monitorId}}",
                "check"
              ]
            }
          }
        },
        {
          "name": "Toggle Monitor Active Status",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/monitors/{{monitorId}}/toggle",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "monitors",
                "{{monitorId}}",
                "toggle"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Logs & Metrics",
      "item": [
        {
          "name": "Get Monitor Logs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/monitors/{{monitorId}}/logs?limit=50",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "monitors",
                "{{monitorId}}",
                "logs"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "50",
                  "description": "Number of logs to return"
                }
              ]
            }
          }
        },
        {
          "name": "Get Monitor Uptime",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/monitors/{{monitorId}}/uptime",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "monitors",
                "{{monitorId}}",
                "uptime"
              ]
            }
          }
        },
        {
          "name": "Get Monitor Response Time",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/monitors/{{monitorId}}/response-time",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "monitors",
                "{{monitorId}}",
                "response-time"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Dashboard Summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/dashboard/summary",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "dashboard",
                "summary"
              ]
            }
          }
        },
        {
          "name": "Get Dashboard Response Chart",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/dashboard/response-chart",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "dashboard",
                "response-chart"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Incidents",
      "item": [
        {
          "name": "Get Incidents",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/incidents?status=active",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "incidents"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "active",
                  "description": "Status filter (e.g., active, resolved)"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Performance",
      "item": [
        {
          "name": "Get Performance Overview",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/performance/overview",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "performance",
                "overview"
              ]
            }
          }
        },
        {
          "name": "Get Performance Trends",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/performance/trends",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "performance",
                "trends"
              ]
            }
          }
        }
      ]
    }
  ]
}
